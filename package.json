{
	"name": "landing-page",
	"private": true,
	"version": "0.0.1",
	"packageManager": "pnpm@10.22.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"deploy:docker": "docker compose build --no-cache && docker compose up -d",
		"sqlite:web:start": "docker rm -f sqlite-web >/dev/null 2>&1 || true && docker run --rm -d --name sqlite-web -p 8081:8080 -v \"$PWD/data:/data\" python:3.12-slim sh -lc \"pip install --no-cache-dir sqlite-web && sqlite_web /data/finance.sqlite --host 0.0.0.0 --port 8080\"",
		"sqlite:web:stop": "docker stop sqlite-web >/dev/null 2>&1 || true",
		"sqlite:web:logs": "docker logs -f sqlite-web"
	},
	"devDependencies": {
		"@eslint/compat": "latest",
		"@eslint/js": "latest",
		"@iconify/json": "^2.2.482",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"plaid": "^42.2.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.6.5",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"unplugin-icons": "^23.0.1",
		"vite": "^7.3.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"dependencies": {
		"@fontsource-variable/google-sans-flex": "^5.2.3",
		"@lucide/svelte": "^1.17.0",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0"
	}
}
